    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader, SubsetRandomSampler\n",
    "import pandas as pd\n",
    "import os\n",
    "import numpy as np\n",
    "from sklearn.model_selection import KFold"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "10d0d08c",
   "metadata": {},
   "outputs": [],
   "source": [
    "csv_filename = \"dummy_data.csv\"\n",
    "dummy_data = pd.DataFrame({\n",
    "    'feature1': torch.randn(1000).numpy(),\n",
    "    'feature2': torch.randn(1000).numpy(),\n",
    "    'feature3': torch.randn(1000).numpy(),\n",
    "    'label': torch.randint(0, 2, (1000,)).numpy()\n",
    "})\n",
    "dummy_data.to_csv(csv_filename, index=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "35d81a16",
   "metadata": {},
   "outputs": [],
   "source": [
    "class CSVDataset(Dataset):\n",
    "    def __init__(self, csv_file):\n",
    "        # Loads teh CSV file\n",
    "        self.df = pd.read_csv(csv_file)\n",
    "\n",
    "    def __len__(self):\n",
    "        # Number of samples\n",
    "        return len(self.df)\n",
    "    \n",
    "    def __getitem__(self, idx):\n",
    "        # Fetch a feature, all columns except last one which should be a label\n",
    "        features = self.df.iloc[idx, :-1].values\n",
    "        label = self.df.iloc[idx, -1]\n",
    "\n",
    "        features_tensor = torch.tensor(features, dtype = torch.float32)\n",
    "        label_tensor = torch.tensor(label, dtype = torch.long)\n",
    "\n",
    "        return features_tensor, label_tensor\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "8520a42a",
   "metadata": {},
   "outputs": [],
   "source": [
    "class ClassifierModel(nn.Module):\n",
    "    def __init__(self):\n",
    "        super(ClassifierModel, self).__init__()\n",
    "        # 3 input features -> 16 hidden units -> 2 outputs\n",
    "        self.fc1 = nn.Linear(3, 16)\n",
    "        self.relu = nn.ReLU()\n",
    "        self.fc2 = nn.Linear(16, 2)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.fc1(x)\n",
    "        x = self.relu(x)\n",
    "        x = self.fc2(x)\n",
    "        return x\n",
    "    \n",
    "def reset_weights(m):\n",
    "    if isinstance(m, nn.Linear):\n",
    "        m.reset_parameters()"
   ]
  },
